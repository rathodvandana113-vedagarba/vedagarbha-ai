generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  name           String?
  email          String    @unique
  passwordHash   String
  credits        Float     @default(10)
  dailyFreeCredits Float   @default(3)
  lastClaimDate  String?
  studentStatus  String    @default("none")
  role           String    @default("USER")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}